# =============================================================================
# SiliconBeest — Root .gitignore
# =============================================================================

# --- Dependencies ---
node_modules/

# --- Build outputs ---
dist/
dist-ssr/

# --- Wrangler / Cloudflare ---
.wrangler/
.dev.vars*
!.dev.vars.example

# --- Environment / Secrets ---
.env
.env.local
.env.*.local
!.env.example

# --- Instance config (create from config.env.example) ---
scripts/config.env

# --- Logs ---
logs/
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# --- OS ---
.DS_Store
Thumbs.db
Desktop.ini

# --- Editor / IDE ---
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*~

# --- TypeScript ---
*.tsbuildinfo

# --- Test / Coverage ---
coverage/
*.lcov
.nyc_output/
__screenshots__/

# --- Cache ---
.cache/
.eslintcache
.stylelintcache
*.timestamp-*-*.mjs

# --- Backups (generated by scripts/backup.sh) ---
backups/

# --- Misc ---
*.tgz
*.pid
*.seed
*.pid.lock


.claude/
.tmp/
.omc/