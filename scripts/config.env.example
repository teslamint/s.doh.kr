# =============================================================================
# SiliconBeest — Script Configuration Overrides
#
# Copy this file to config.env and edit to customize resource names.
#
# Usage:
#   cp scripts/config.env.example scripts/config.env
#   # Edit values, then run: ./scripts/sync-config.sh --apply
#
# For GitHub Actions CI, set these as Repository Variables instead.
# =============================================================================

# Master prefix — changes all resource name defaults at once
# PROJECT_PREFIX=myinstance

# ---------------------------------------------------------------------------
# Instance identity
# ---------------------------------------------------------------------------
# INSTANCE_DOMAIN=social.example.com
# INSTANCE_TITLE=My SiliconBeest Instance
# REGISTRATION_MODE=open

# ---------------------------------------------------------------------------
# Worker name overrides (uncomment to customize)
# ---------------------------------------------------------------------------
# MAIN_WORKER_NAME=myinstance
# CONSUMER_NAME=myinstance-consumer
# EMAIL_SENDER_NAME=myinstance-email

# ---------------------------------------------------------------------------
# Cloudflare resource name overrides (uncomment to customize)
# ---------------------------------------------------------------------------
# D1_DATABASE_NAME=myinstance-db
# R2_BUCKET_NAME=myinstance-media
# KV_CACHE_TITLE=myinstance-cache
# KV_SESSIONS_TITLE=myinstance-sessions
# KV_FEDIFY_TITLE=myinstance-fedify-kv
# QUEUE_FEDERATION=myinstance-federation
# QUEUE_INTERNAL=myinstance-internal
# QUEUE_EMAIL=myinstance-email
# QUEUE_DLQ=myinstance-federation-dlq

# ---------------------------------------------------------------------------
# Cloudflare resource IDs
# Filled automatically by setup.sh, or copy from Cloudflare dashboard.
# When set, sync-config.sh --apply uses these directly (no API calls needed).
# ---------------------------------------------------------------------------
# D1_DATABASE_ID=
# KV_CACHE_ID=
# KV_SESSIONS_ID=
# KV_FEDIFY_ID=
