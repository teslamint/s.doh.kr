{
	"name": "siliconbeest-vue",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "run-p type-check \"build-only {@}\" --",
		"preview": "pnpm run build && pnpm wrangler dev",
		"build-only": "vite build",
		"type-check": "vue-tsc --build",
		"deploy": "pnpm run build && pnpm wrangler deploy",
		"cf-typegen": "pnpm wrangler types",
		"test": "vitest run --config vitest.config.ts && vitest run --config vitest.worker.config.ts",
		"test:vue": "vitest run --config vitest.config.ts",
		"test:worker": "vitest run --config vitest.worker.config.ts",
		"test:watch": "vitest --config vitest.config.ts",
		"lint": "oxlint -c oxlint.config.ts server/worker/services server/worker/repositories server/worker/middleware server/worker/utils server/worker/webpush server/worker/types && eslint",
		"lint:fix": "oxlint -c oxlint.config.ts --fix server/worker/services server/worker/repositories server/worker/middleware server/worker/utils server/worker/webpush server/worker/types && eslint --fix"
	},
	"dependencies": {
		"@fedify/cfworkers": "^2.1.5",
		"@fedify/fedify": "^2.2.1",
		"@fedify/hono": "^2.1.5",
		"@fedify/vocab": "^2.1.5",
		"@fedify/webfinger": "^2.1.5",
		"@headlessui/vue": "^1.7.23",
		"@js-temporal/polyfill": "^0.5.1",
		"@logtape/logtape": "^2.0.5",
		"@sentry/vue": "^10.45.0",
		"@vueuse/core": "^14.2.1",
		"bcryptjs": "^3.0.3",
		"hono": "^4.6.20",
		"marked": "^17.0.5",
		"neverthrow": "^8.2.0",
		"pinia": "^3.0.4",
		"remeda": "^2.33.7",
		"ulid": "^3.0.2",
		"valibot": "^1.3.1",
		"vue": "^3.5.29",
		"vue-i18n": "^11.3.0",
		"vue-router": "^5.0.3"
	},
	"devDependencies": {
		"@cloudflare/vite-plugin": "^1.30.0",
		"@cloudflare/vitest-pool-workers": "^0.14.0",
		"@eslint/js": "^10.0.1",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.2.2",
		"@tsconfig/node24": "^24.0.4",
		"@types/bcryptjs": "^2.4.6",
		"@types/node": "^24.12.0",
		"@vitejs/plugin-vue": "^6.0.4",
		"@vue/test-utils": "^2.4.6",
		"@vue/tsconfig": "^0.8.1",
		"eslint": "^10.2.0",
		"eslint-plugin-functional": "^9.0.4",
		"eslint-plugin-oxlint": "^1.58.0",
		"happy-dom": "^20.8.4",
		"npm-run-all2": "^8.0.4",
		"oxlint": "^1.58.0",
		"oxlint-tsgolint": "^0.19.0",
		"tailwindcss": "^4.2.2",
		"typescript": "~5.9.3",
		"typescript-eslint": "^8.58.0",
		"vite": "^7.3.1",
		"vite-plugin-vue-devtools": "^8.0.6",
		"vitest": "^4.1.0",
		"vue-tsc": "^3.2.5",
		"wrangler": "^4.80.0"
	},
	"engines": {
		"node": "^20.19.0 || >=22.12.0"
	}
}
