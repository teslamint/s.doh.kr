# SiliconBeest Vue Frontend Environment
# Copy to .env and fill in values (auto-generated by scripts/setup.sh)

# Instance domain (used for meta tags, links)
VITE_INSTANCE_DOMAIN=social.example.com

# VAPID public key for Web Push subscription (base64url-encoded, 65 bytes)
VITE_VAPID_PUBLIC_KEY=

# Sentry DSN for error tracking (optional — leave blank to disable)
# Get your DSN at https://sentry.io
# VITE_SENTRY_DSN=https://your-key@o000000.ingest.sentry.io/0000000
